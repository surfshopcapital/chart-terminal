generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Ticker {
  id          String   @id @default(cuid())
  symbol      String   @unique
  name        String
  type        String   // 'equity' | 'etf' | 'index' | 'fx' | 'commodity' | 'rate'
  category    String   // 'fx' | 'global_index' | 'rate' | 'commodity' | 'us_sector' | 'sector_leader' | 'thematic'
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listItems ListItem[]
  notes     Note[]
  ratings   Rating[]
  reviews   Review[]
}

model List {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ListItem[]
}

model ListItem {
  id        String   @id @default(cuid())
  listId    String
  tickerId  String
  position  Int
  createdAt DateTime @default(now())

  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)
  ticker Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@unique([listId, tickerId])
}

model Note {
  id        String   @id @default(cuid())
  tickerId  String
  userId    String?
  content   String   @default("")
  updatedAt DateTime @updatedAt

  ticker Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@unique([tickerId, userId])
}

model Rating {
  id        String   @id @default(cuid())
  tickerId  String
  userId    String?
  date      String   // 'YYYY-MM-DD'
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticker Ticker @relation(fields: [tickerId], references: [id], onDelete: Cascade)

  @@unique([tickerId, userId, date])
}

model Session {
  id            String    @id @default(cuid())
  userId        String?
  date          String    // 'YYYY-MM-DD'
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  durationSecs  Int       @default(0)
  completionPct Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reviews Review[]

  @@unique([userId, date])
}

model Review {
  id         String   @id @default(cuid())
  sessionId  String
  tickerId   String
  timeframe  String   // 'D' | 'W' | 'M'
  reviewedAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  ticker  Ticker  @relation(fields: [tickerId], references: [id], onDelete: Cascade)
}
